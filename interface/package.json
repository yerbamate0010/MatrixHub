{
	"name": "matrixhub",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"i18n:build": "node ./scripts/ensure-paraglide.mjs",
		"i18n:build:raw": "node ./node_modules/@inlang/paraglide-js/bin/run.js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"dev": "npm run i18n:build && vite dev --host",
		"build": "npm run i18n:build && vite build",
		"build:analyze": "npm run i18n:build && vite build --mode analyze",
		"preview": "vite preview",
		"check": "npm run i18n:build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run i18n:build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "npm run i18n:build && vitest",
		"test:ui": "npm run i18n:build && vitest --ui",
		"test:run": "npm run i18n:build && vitest run",
		"test:coverage": "npm run i18n:build && vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install chromium",
		"size": "npm run build && node ./scripts/check-build-size.mjs",
		"deps:check": "npm run i18n:build && dependency-cruiser --ignore-known .dependency-cruiser-known-violations.json src",
		"deps:baseline": "npm run i18n:build && dependency-cruiser --output-type baseline src > .dependency-cruiser-known-violations.json",
		"deps:graph": "npm run i18n:build && dependency-cruiser --output-type dot src | dot -T svg > dependency-graph.svg",
		"unused:check": "knip --reporter symbols --no-progress --exclude unresolved",
		"deps:update": "ncu -u",
		"bundle:analyze": "bundle-wizard",
		"lhci": "lhci autorun",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@iconify-json/tabler": "^1.2.26",
		"@inlang/paraglide-js": "2.9.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.58.0",
		"@rollup/rollup-darwin-arm64": "^4.57.1",
		"@size-limit/preset-app": "^12.0.0",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.50.1",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/svelte": "^5.3.1",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"bundle-wizard": "^1.6.1",
		"daisyui": "^5.5.14",
		"dependency-cruiser": "^17.3.7",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-security": "^3.0.1",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"knip": "^5.82.1",
		"npm-check-updates": "^19.3.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"rollup": "^4.56.0",
		"rollup-plugin-visualizer": "^6.0.5",
		"size-limit": "^12.0.0",
		"svelte": "5.48.3",
		"svelte-check": "^4.3.5",
		"svelte-eslint-parser": "^1.4.1",
		"tailwindcss": "^4.1.18",
		"terser": "^5.46.0",
		"typescript": "^5.9.3",
		"unplugin-icons": "^23.0.1",
		"vite": "7.3.1",
		"vite-plugin-compression": "^0.5.1",
		"vitest": "^4.0.18"
	},
	"type": "module",
	"dependencies": {
		"glob": "^13.0.0",
		"jwt-decode": "^4.0.0",
		"simple-keyboard": "^3.8.93",
		"svelte-modals": "^2.0.1",
		"uplot": "^1.6.32",
		"zod": "^4.3.6"
	},
	"overrides": {
		"tar-fs": "^2.1.1"
	}
}
