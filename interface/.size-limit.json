[
	{
		"name": "Client Bundle (Gzip)",
		"path": "build/_app/immutable/**/*.js",
		"limit": "400 KB",
		"gzip": true
	},
	{
		"name": "CSS Bundle (Gzip)",
		"path": "build/_app/immutable/**/*.css",
		"limit": "50 KB",
		"gzip": true
	},
	{
		"name": "Total Build Size",
		"path": "build/**/*",
		"limit": "1.5 MB",
		"exclude": ["build/**/*.gz"]
	}
]
